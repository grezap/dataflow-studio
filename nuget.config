<?xml version="1.0" encoding="utf-8"?>
<!--
  DataFlow Studio package sources.

  External packages come from nuget.org; the Nexus.* family comes from GitHub Packages
  (grezap/nexus-shared). GitHub Packages requires auth even for public feeds, so the token is
  supplied via the GITHUB_PACKAGES_TOKEN environment variable (never committed) — set it to a
  token carrying read:packages (or write:packages, which includes read) before `dotnet restore`.
  Package source mapping keeps Nexus.* on the GitHub feed and everything else on nuget.org.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github-nexus" value="https://nuget.pkg.github.com/grezap/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-nexus">
      <package pattern="Nexus.*" />
    </packageSource>
  </packageSourceMapping>
  <packageSourceCredentials>
    <github-nexus>
      <add key="Username" value="grezap" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_TOKEN%" />
    </github-nexus>
  </packageSourceCredentials>
</configuration>
