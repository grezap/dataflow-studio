<?xml version="1.0" encoding="utf-8"?>
<!--
  DataFlow Studio package sources.

  Week 1 (this slice): nuget.org only.
  Week 2 will add the GitHub Packages source for the grezap/nexus-shared
  Nexus.* family once dataflow-studio begins consuming those packages
  (Nexus.Kafka / Nexus.Avro / Nexus.Vault / Nexus.Observability / Nexus.Primitives).
  Package source mapping keeps nuget.org and the Nexus.* feed cleanly separated.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
